# Copie este arquivo para .env e preencha os valores
# cp .env.example .env

RAILS_MAX_THREADS=5
SOLID_QUEUE_IN_PUMA=true

# Produção (via Kamal secrets, não vai aqui):
# RAILS_MASTER_KEY=

# Autenticação do endpoint admin (/registration/show)
# OBRIGATÓRIO em produção — sem ADMIN_PASSWORD o endpoint retorna 401 sempre
ADMIN_USER=admin
ADMIN_PASSWORD=

# Domínios permitidos em produção (separados por vírgula)
# Ex: ALLOWED_HOSTS=openuf.com.br,www.openuf.com.br
ALLOWED_HOSTS=

# Chaves de criptografia do CPF (Active Record Encryption)
# Gere novas chaves com: bin/rails db:encryption:init
# NUNCA reutilize estas chaves entre ambientes
AR_ENCRYPTION_PRIMARY_KEY=
AR_ENCRYPTION_DETERMINISTIC_KEY=
AR_ENCRYPTION_KEY_DERIVATION_SALT=
