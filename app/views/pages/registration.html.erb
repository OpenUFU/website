<% content_for :title, "Inscrição - Projeto OpenUFU" %>

<nav class="navbar">
    <div class="nav-container">
        <div class="logo">Comunidade OpenUFU</div>
        <a href="/" class="nav-link">Voltar ao Manifesto</a>
    </div>
</nav>

<main class="content-wrapper">
    <article class="manifesto">
        <header class="manifesto-header reveal">
            <span class="eyebrow">Formulário de Inscrição</span>
            <h1 class="title">Junte-se ao Projeto</h1>
            <p class="subtitle">Preencha os dados abaixo para manifestar seu interesse em participar da equipe.</p>
        </header>

        <section class="form-section reveal">
            <%= form_with url: "/registration", method: :post, id: "inscricaoForm", class: "custom-form" do %>
                <div class="form-group">
                    <label for="nomeCompleto">Nome Completo</label>
                    <input type="text" id="nomeCompleto" name="registration[nome_completo]" required
                        placeholder="Digite seu nome completo">
                </div>
                <div class="form-group">
                    <label for="email">E-mail</label>
                    <input type="email" id="email" name="registration[email]" required placeholder="exemplo@ufu.br">
                </div>

                <div class="form-group">
                    <label for="cpf">CPF</label>
                    <input type="text" id="cpf" name="registration[cpf]" required placeholder="000.000.000-00">
                </div>

                <div class="form-group">
                    <label for="curso">Curso</label>
                    <input type="text" id="curso" name="registration[curso]" required placeholder="Ex: Sistemas de Informação">
                </div>

                <div class="form-group">
                    <label for="matricula">Matrícula</label>
                    <input type="text" id="matricula" name="registration[matricula]" required placeholder="Digite sua matrícula">
                </div>


                <div class="form-group">
                    <label for="periodo">Período</label>
                    <input type="number" id="periodo" name="registration[periodo]" required placeholder="Ex: 5" min="1" max="14">
                </div>

                <div class="form-group">
                    <label for="contribuicao">Como você acredita poder contribuir para o projeto?</label>
                    <textarea id="contribuicao" name="registration[contribuicao]" required
                        placeholder="Descreva suas habilidades, experiências ou áreas em que gostaria de atuar no projeto."
                        rows="5"></textarea>
                </div>

                <button type="submit" class="btn-submit">Confirmar Inscrição</button>
            <% end %>
            <div id="formFeedback" class="form-feedback hidden">
                Inscrição recebida com sucesso! Em breve entraremos em contato.
            </div>
        </section>
    </article>
</main>

<footer class="manifesto-footer">
    <p>&copy; 2026 Grupo de Extensão OpenUFU • Universidade Federal de Uberlândia</p>
</footer>

<script src="/script.js"></script>
